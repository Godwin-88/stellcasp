# =============================================================================
# Alerting & Webhooks (EP-01, EP-07)
# =============================================================================
ALERT_WEBHOOK_URL=https://hooks.example.com/compliance-alert
SECURITY_ALERT_WEBHOOK_URL=https://hooks.example.com/security-alert

# =============================================================================
# Development Flags
# =============================================================================
DEMO_MODE=true
