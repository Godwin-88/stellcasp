# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=zkkyc
POSTGRES_PASSWORD=password
POSTGRES_DB=zkkyc

# ZK Configuration
ENTITY_SALT=change_me_in_production
PLATFORM_SIGNING_KEY=ed25519_signing_key_hex_here
DATA_ENCRYPTION_KEY=aes256_gcm_key_base64_here

# Risk Engine Configuration
HIGH_RISK_NRS_THRESHOLD=0.75

# API Configuration
API_RATE_LIMIT_DEFAULT=60
API_RATE_LIMIT_MAX=600

# x402 Micropayment Configuration
X402_PRICE_CSPR=0.001
CASPER_TREASURY_PUBLIC_KEY=casper_testnet_public_key_here
CASPER_TREASURY_PRIVATE_KEY=casper_testnet_private_key_here

# Webhook Configuration
ALERT_WEBHOOK_URL=https://hooks.example.com/compliance-alert
SECURITY_ALERT_WEBHOOK_URL=https://hooks.example.com/security-alert

# LLM Configuration
GROQ_API_KEY=your_groq_api_key_here

# Admin Configuration
ADMIN_SECRET=admin_secret_key_here

# Contract Addresses (populated after deployment)
STELLAR_VERIFIER_CONTRACT=
CASPER_COMPLIANCE_ORACLE_CONTRACT=
CASPER_IDENTITY_REGISTRY_CONTRACT=