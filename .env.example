# =============================================================================
# Neo4j Configuration (EP-01)
# =============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# =============================================================================
# PostgreSQL Configuration (EP-07)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=zkkyc
POSTGRES_PASSWORD=password
POSTGRES_DB=zkkyc

# =============================================================================
# Security & Privacy (EP-07)
# =============================================================================
ENTITY_SALT=change_me_in_production
PLATFORM_SIGNING_KEY=ed25519_signing_key_hex_here
DATA_ENCRYPTION_KEY=aes256_gcm_key_base64_here
DISCLOSURE_API_KEY=disclosure_api_key_here

# =============================================================================
# Risk Engine Configuration (EP-01)
# =============================================================================
HIGH_RISK_NRS_THRESHOLD=0.75
MANIFOLD_THRESHOLD=0.20

# Six-factor CI weights (must sum to 1.0)
CI_WEIGHT_L=0.10
CI_WEIGHT_C=0.20
CI_WEIGHT_J=0.15
CI_WEIGHT_S=0.25
CI_WEIGHT_A=0.20
CI_WEIGHT_B=0.10

# =============================================================================
# API Configuration (EP-05)
# =============================================================================
API_RATE_LIMIT_DEFAULT=60
API_RATE_LIMIT_MAX=600
ADMIN_SECRET=admin_secret_key_here

# =============================================================================
# Casper x402 Micropayment (EP-05)
# =============================================================================
X402_PRICE_CSPR=0.001
X402_CHALLENGE_EXPIRY_SECONDS=30
CASPER_TREASURY_PUBLIC_KEY=casper_testnet_public_key_here
CASPER_TREASURY_PRIVATE_KEY=casper_testnet_private_key_here

# =============================================================================
# Casper AI Toolkit (augmentation per casper.md)
# =============================================================================
CASPER_X402_FACILITATOR_URL=http://localhost:3000
CASPER_MCP_SERVER_URL=http://localhost:3001
CASPER_AGENT_PUBLIC_KEY=
CASPER_AGENT_PRIVATE_KEY=
CASPER_USE_FACILITATOR=true
CASPER_USE_MCP=true
CASPER_USE_SS_EVENTS=true

# =============================================================================
# Casper Node / Chain (EP-04)
# =============================================================================
CASPER_NODE_ADDRESS=https://rpc.testnet.cspr.network
CASPER_CHAIN_NAME=casper-test
CASPER_SECRET_KEY_PATH=
CASPER_COMPLIANCE_ORACLE_CONTRACT=
CASPER_IDENTITY_REGISTRY_CONTRACT=

# =============================================================================
# Stellar Soroban (EP-02, EP-03)
# =============================================================================
STELLAR_HORIZON_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_VERIFIER_CONTRACT=
STELLAR_PASSPORT_CONTRACT=
STELLAR_SOURCE_SECRET=
STELLAR_ORACLE_AUTHORITY=
STELLAR_BASE_FEE=100

# =============================================================================
# EVM / L2 (EP-08)
# =============================================================================
ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
ETHEREUM_CHAIN_ID=11155111
ETHEREUM_VERIFIER_CONTRACT_ADDRESS=
ETHEREUM_PASSPORT_CONTRACT_ADDRESS=
ETHEREUM_ORACLE_AUTHORITY_PRIVATE_KEY=
ETHERSCAN_API_KEY=

BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/...
BASE_CHAIN_ID=8453
BASE_VERIFIER_CONTRACT_ADDRESS=
BASE_PASSPORT_CONTRACT_ADDRESS=

ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
